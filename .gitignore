# =======================
# JOOMLA .GITIGNORE
# =======================

# Configurações sensíveis
configuration.php
.htaccess

# Cache e arquivos temporários
/cache/*
/tmp/*
/logs/*
/administrator/cache/*
/administrator/logs/*

# Sessões e dados temporários
/administrator/tmp/*
/tmp/install_*

# Backups e dumps de banco
*.sql
/administrator/components/com_akeeba/backup/*
backup*.zip
backup*.tar.gz
*.dump

# EXCEÇÃO: Permitir arquivos SQL de estrutura dos componentes
!/administrator/components/*/sql/*.sql
!/components/*/sql/*.sql
!/plugins/*/sql/*.sql
!/modules/*/sql/*.sql
!/administrator/components/*/sql/updates/*.sql

# Arquivos de sistema
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~
*.swp
*.swo

# IDEs e editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.buildpath

# Arquivos temporários
*.tmp
*.temp
*.log
error_log
.error_log

# Uploads pesados (opcional - descomente se necessário)
# /images/stories/*
# /images/banners/*
# /media/system/videos/*

# Node modules se usar ferramentas de build
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos de desenvolvimento
.env
.env.local
.env.development
.env.test
.env.production

# Certificados SSL
*.pem
*.key
*.crt
*.csr

# Arquivos compactados desnecessários
*.zip
*.rar
*.7z
*.tar
*.gz

# EXCEÇÃO: Permitir arquivos de instalação de extensões se necessário
# !install_*.zip
